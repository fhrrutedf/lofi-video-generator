# ====================================
# API Keys Configuration
# ====================================
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env file to Git!

# 🎵 Kie.ai API (Music & Video Generation)
# Get your key from: https://kie.ai/dashboard/api-keys
KIE_API_KEY=your_kie_api_key_here

# 🤖 Google Gemini AI (Prompt Orchestration)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 🌐 OpenRouter AI (Free Alternative to Gemini)
# Get your key from: https://openrouter.ai/keys
# Supports free models like: google/gemini-2.0-flash-exp:free, meta-llama/llama-4-maverick:free
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 🎯 AI Provider Choice (optional)
# Options: "gemini", "openrouter", "auto" (tries Gemini first, falls back to OpenRouter)
# Default: "auto"
AI_PROVIDER=auto

# 🎬 Pexels API (Stock Videos & Images)
# Get your key from: https://www.pexels.com/api/new/
PEXELS_API_KEY=your_pexels_api_key_here

# ====================================
# Optional: YouTube Upload
# ====================================
# You'll need to create a project in Google Cloud Console
# and download client_secrets.json

# ====================================
# Notes
# ====================================
# 1. Never share or commit your actual .env file
# 2. Keep your API keys secure
# 3. Some APIs have free tiers with limits
# 4. Check each service's documentation for usage limits
